{
    "log_file": "data/crabber.log",
    "credential_refresh_interval": 3600,
    "crabbers": [
        {
            "name": "nickname",
            "room_id": 12345,
            "components": [
                {
                    "type": "danmu_logger"
                },
                {
                    "type": "gift_logger"
                },
                {
                    "type": "event_logger",
                    "events": [
                        "SPECIAL_GIFT",
                        "SYS_MSG"
                    ]
                },
                {
                    "type": "notify",
                    "config": {
                        "channels": [
                            {
                                "name": "ntfy_channel",
                                "provider": "ntfy",
                                "enabled": true,
                                "config": {
                                    "endpoint": "https://ntfy.sh/",
                                    "topic": "my_topic",
                                    "priority": 3,
                                    "token": "tk_...",
                                    "replace_host": {
                                        "www.example.com": "www.replaced.com"
                                    }
                                }
                            }
                        ]
                    }
                }
            ],
            "database": [
                {
                    "adapter": "sqlite",
                    "config": {
                        "path": "path/to/database.sqlite"
                    }
                },
                {
                    "adapter": "cloudflare",
                    "config": {
                        "account_id": "your_account_id",
                        "api_token": "your_api_token",
                        "dataset_id": "your_dataset_id"
                    }
                }
            ]
        }
    ]
}