{
    "log_file": "data/crabber.log",
    "credential_refresh_interval": 3600,
    "crabbers": [
        {
            "name": "nickname",
            "room_id": 12345,
            "components": [
                { "type": "danmu_logger" },
                { "type": "gift_logger" },
                {
                    "type": "event_logger",
                    "events": ["SPECIAL_GIFT", "SYS_MSG"]
                },
                {
                    "type": "recorder",
                    "config": {
                        "path": "data/recordings",
                        "template": "${date}_${room_id}_${title}.flv"
                    }
                },
                {
                    "type": "chatter",
                    "config": {
                        "on_live": {"message": "欢迎xxxx！chatter组件只在开播中生效哦"},
                        "on_cron": [
                            {
                                "interval": {"minutes": 30, "seconds": 1},
                                "message": [
                                    "喜欢主播的点点关注不迷路~",
                                    "点个赞支持一下吧！"
                                ],
                                "random": true
                            },
                            {
                                "schedule": "0 * * * *",
                                "message": "整点报时：现在是${time}，记得起来活动一下哦"
                            }
                        ]
                    }
                },
                {
                    "type": "notify",
                    "config": {
                        "channels": [
                            {
                                "name": "ntfy_channel",
                                "provider": "ntfy",
                                "enabled": true,
                                "config": {
                                    "endpoint": "https://ntfy.sh/",
                                    "topic": "my_topic",
                                    "priority": 3,
                                    "token": "tk_...",
                                    "replace_host": {
                                        "www.example.com": "www.replaced.com"
                                    }
                                }
                            },
                            {
                                "name": "napcat-service",
                                "provider": "napcat",
                                "enabled": true,
                                "config": {
                                    "groups": [123456789, 1145141919810]
                                }
                            }
                        ]
                    }
                }
            ],
            "database": [
                {
                    "adapter": "sqlite",
                    "config": {
                        "path": "path/to/database.sqlite"
                    }
                },
                {
                    "adapter": "cloudflare",
                    "config": {
                        "account_id": "your_account_id",
                        "api_token": "your_api_token",
                        "dataset_id": "your_dataset_id"
                    }
                }
            ],
            "services": [
                {
                    "type": "napcat",
                    "config": {
                        "endpoint": "http://127.0.0.1:3000",
                        "token": "???????????????"
                    }
                }
            ]
        }
    ]
}